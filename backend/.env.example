APP_NAME=Vibyra
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Password-recovery Universal Link / App Link rollout.
# Modes: legacy (custom scheme), dual (verified primary + legacy fallback), verified.
RECOVERY_LINK_MODE=dual
RECOVERY_VERIFIED_URL=https://links.vibyra.app/reset-password
# Replace TEAMID with the Apple Developer Team ID before enabling production links.
RECOVERY_APPLE_APP_ID=TEAMID.app.vibyra.mobile
RECOVERY_ANDROID_PACKAGE=app.vibyra.mobile
# Comma-separated SHA-256 fingerprints from Play App Signing, not an invented/upload key.
RECOVERY_ANDROID_SHA256_CERT_FINGERPRINTS=

# Defaults to enabled for local/testing and disabled for other environments.
# VIBYRA_LEGACY_DESKTOP_ROUTES_ENABLED=false

# Production browser origins, comma-separated and matched exactly.
VIBYRA_CORS_ALLOWED_ORIGINS=
# Defaults to true only in local/testing. Keep false in production.
# VIBYRA_CORS_ALLOW_ANY_ORIGIN=false

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

OPENAI_API_KEY=
OPENAI_MODERATION_ENABLED=true
OPENAI_MODERATION_FAIL_CLOSED=true
OPENAI_MODERATION_MODEL=omni-moderation-latest
OPENAI_MODERATION_URL=https://api.openai.com/v1/moderations
# Emergency launch switch. Keep false unless publish review must be temporarily bypassed.
PUBLISH_REVIEW_TEMPORARILY_DISABLED=false
PUBLISH_REVIEW_FORCE_APPROVE_UNDER_REVIEW=false
OPENROUTER_API_KEY=
OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_RESPONSES_URL=https://openrouter.ai/api/v1/responses
OPENROUTER_ANTHROPIC_URL=https://openrouter.ai/api/v1/messages

# Stripe (web checkout). All optional in development.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=https://vibyra.app/billing/success
STRIPE_CANCEL_URL=https://vibyra.app/billing/cancel
STRIPE_PORTAL_RETURN_URL=https://vibyra.app/account
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_ANNUAL=
STRIPE_PRICE_BUILDER_MONTHLY=
STRIPE_PRICE_BUILDER_ANNUAL=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_TOPUP_500=
STRIPE_PRICE_TOPUP_1500=
STRIPE_PRICE_TOPUP_4000=

# Apple / Google IAP (mobile)
APPLE_IAP_SHARED_SECRET=
APPLE_IAP_VERIFY_URL=https://buy.itunes.apple.com/verifyReceipt
APPLE_IAP_SANDBOX_URL=https://sandbox.itunes.apple.com/verifyReceipt
GOOGLE_IAP_PACKAGE_NAME=
# Raw JSON, base64-encoded JSON, or an absolute path to the service-account JSON file.
GOOGLE_IAP_SERVICE_ACCOUNT_JSON=
GOOGLE_IAP_API_URL=https://androidpublisher.googleapis.com/androidpublisher/v3

# Native Google and Apple identity-token verification.
GOOGLE_AUTH_CLIENT_IDS=
GOOGLE_AUTH_JWKS_URL=https://www.googleapis.com/oauth2/v3/certs
APPLE_AUTH_CLIENT_IDS=app.vibyra.mobile
APPLE_AUTH_JWKS_URL=https://appleid.apple.com/auth/keys

# MaxMind GeoLite2 City database for account device locations.
MAXMIND_ACCOUNT_ID=
MAXMIND_LICENSE_KEY=
MAXMIND_UPDATE_DAYS=7
