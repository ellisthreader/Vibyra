    "expo": "~54.0.33",
    "expo-asset": "~12.0.12",
    "expo-build-properties": "~1.0.10",
    "expo-haptics": "~15.0.8",
    "expo-iap": "^4.2.3",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-network": "~8.0.8",
    "expo-status-bar": "~3.0.9",
    "lottie-react-native": "~7.3.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
