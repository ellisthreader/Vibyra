{
  "expo": {
    "name": "Vibyra",
    "slug": "vibyra",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "vibyra",
    "icon": "./src/assets/vibyra.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.vibyra.mobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocalNetworkUsageDescription": "Vibyra connects to the desktop app on your local Wi-Fi network.",
        "NSPhotoLibraryUsageDescription": "Vibyra lets you choose images for your profile picture and project publishing.",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "android": {
      "package": "app.vibyra.mobile",
      "usesCleartextTraffic": true
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-asset",
      [
        "expo-image-picker",
        {
          "photosPermission": "Vibyra lets you choose images for your profile picture and project publishing."
        }
      ],
      "expo-iap",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "2.0.21"
          }
        }
      ]
    ]
  }
}
