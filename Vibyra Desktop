#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")"

PORT="${VIBYRA_AGENT_PORT:-4317}"
APP_URL="http://127.0.0.1:${PORT}/desktop"
CHROME_PROFILE="$HOME/.vibyra-desktop-window"
ELECTRON_BIN=""

if [ -x "node_modules/.bin/electron" ]; then
  ELECTRON_BIN="node_modules/.bin/electron"
elif [ -x "../codingterminal/node_modules/.bin/electron" ]; then
  ELECTRON_BIN="../codingterminal/node_modules/.bin/electron"
fi

open_window() {
  if [ -n "$ELECTRON_BIN" ] && [ -f "desktop/electron-main.cjs" ]; then
    ELECTRON_RUN_AS_NODE= VIBYRA_DESKTOP_URL="$APP_URL" "$ELECTRON_BIN" --no-sandbox --disable-gpu --disable-gpu-compositing desktop/electron-main.cjs >/dev/null 2>&1 &
  elif command -v google-chrome >/dev/null 2>&1; then
    google-chrome --app="$APP_URL" --class=VibyraDesktop --user-data-dir="$CHROME_PROFILE" --window-size=1040,760 >/dev/null 2>&1 &
  elif command -v chromium >/dev/null 2>&1; then
    chromium --app="$APP_URL" --class=VibyraDesktop --window-size=1040,760 >/dev/null 2>&1 &
  else
    xdg-open "$APP_URL" >/dev/null 2>&1 &
  fi
}

PORT_PIDS="$(lsof -nP -tiTCP:"${PORT}" -sTCP:LISTEN 2>/dev/null || true)"

if [ -n "$PORT_PIDS" ]; then
  if curl -fsS "http://127.0.0.1:${PORT}/health" 2>/dev/null | grep -q '"ok":true'; then
    open_window
    exit 0
  fi
  echo "Port ${PORT} is already in use by a different local server." >&2
  ps -o pid=,cmd= -p "$PORT_PIDS" >&2 || true
  echo "Stop the old Vibyra Desktop process first, then run npm run desktop again." >&2
  echo "Try: kill ${PORT_PIDS}" >&2
  exit 1
fi

if [ ! -f desktop/local-app.mjs ]; then
  echo "Could not find desktop/local-app.mjs" >&2
  exit 1
fi

node desktop/local-app.mjs
