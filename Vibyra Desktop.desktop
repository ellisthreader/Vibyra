[Desktop Entry]
Type=Application
Version=1.0
Name=Vibyra
Comment=Vibyra AI desktop workspace
Exec=/bin/bash -lc "desktop_file=\"\\$1\"; cd \"\\$(dirname \"\\$desktop_file\")\" && exec \"./Vibyra Desktop\"" vibyra %k
Icon=vibyra-login-logo
Terminal=false
Categories=Development;
StartupNotify=true
StartupWMClass=vibyra
